<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVibe"
    android:layout_width="220dp"
    android:layout_height="278dp"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#22FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgVibeExample"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="#33FFFFFF"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_vibe_music" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/imgVibeIcon"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:contentDescription="@null"
                android:padding="10dp"
                android:src="@drawable/ic_vibe_music" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtVibePercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="82%"
            android:textColor="#111111"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtVibeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:text="Bailables"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtVibeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Tus ultimas 4 semanas han sido 82% bailables"
            android:textColor="#CC111111"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtVibeExampleSong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Ejemplo: Song"
            android:textColor="#111111"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtVibeExampleArtist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Artist"
            android:textColor="#AA111111"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/progressVibe"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="82"
            android:progressBackgroundTint="#44FFFFFF" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
